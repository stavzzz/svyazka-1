# Скопируйте в .env и заполните своими значениями. В git не коммитить!

# Telegram
TG_TOKEN=1234567890:AA...ваш-токен-от-BotFather
OWNER_CHAT_ID=111111111            # ваш Telegram id (узнать: @userinfobot)

# ── Модель-классификатор: выберите ОДИН из двух вариантов ──

# Вариант 1 — MiniMax (по умолчанию)
MODEL_FORMAT=minimax
MODEL_API_KEY=ваш-ключ-minimax
MODEL_BASE_URL=https://api.minimax.io/anthropic
MODEL_NAME=MiniMax-M3

# Вариант 2 — Codex по подписке ChatGPT через OpenClaw (раскомментируйте, вариант 1 закомментируйте)
# MODEL_FORMAT=openai
# MODEL_API_KEY=ваш-gateway-токен-openclaw
# MODEL_BASE_URL=http://172.17.0.1:18789/v1
# MODEL_NAME=openclaw/default

# Голосовые (Groq Whisper)
GROQ_API_KEY=gsk_...

# Zoom Server-to-Server OAuth (опционально — без него будет только Google Meet)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Календарь
CALENDAR_ID=primary
FALLBACK_TZ=Europe/Moscow
